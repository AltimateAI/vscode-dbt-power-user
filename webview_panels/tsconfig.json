{
  "compilerOptions": {
    "target": "ES5",
    "useDefineForClassFields": true,
    "lib": ["ES2015", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "outDir": "dist",

    /* Linting */
    "strict": true,
    "strictNullChecks": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "downlevelIteration": true,
    "baseUrl": ".",
    "paths": {
      "@uicore": ["src/uiCore/index.ts"],
      "@lib": ["src/lib/index.ts"],
      "@altimateai/ui-components/lineage": [
        "../../altimate-components/lib/components/lineage/index.ts"
      ],
      "@ac-uicore/shadcn": [
        "../../altimate-components/lib/uiCore/shadcn/index.ts"
      ],
      "@ac-uicore": ["../../altimate-components/lib/uiCore/index.ts"],
      "@ac-assets/*": ["../../altimate-components/lib/assets/*"],
      "@apiHelper": ["../../altimate-components/lib/components/api"],
      "@assets/*": ["src/assets/*"],
      "@modules/*": ["src/modules/*"],
      "@testUtils": ["src/testUtils/index.ts"],
      "@vscodeApi": ["src/modules/vscode/index.ts"],
      "@telemetryEvents": ["../src/telemetry/events.ts"]
    },
    "typeRoots": ["src/modules/queryPanel/components/perspective"]
  },
  "include": [
    "src",
    "vite.config.ts",
    "vite.config.renderer.ts",
    "../src/telemetry/events.ts"
  ],
  "references": [{ "path": "./tsconfig.node.json" }]
}
