{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "outDir": "dist",

    /* Linting */
    "strict": true,
    "strictNullChecks": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "downlevelIteration": true,
    "baseUrl": ".",
    "paths": {
      "@uicore": ["src/uiCore/index.ts"],
      "@lib": ["src/lib/index.ts"],
      "@assets/*": ["src/assets/*"],
      "@modules/*": ["src/modules/*"],
      "@testUtils": ["src/testUtils/index.ts"],
      "@vscodeApi": ["src/modules/vscode/index.ts"],
      "@telemetryEvents": ["../src/telemetry/events.ts"]
    },
    "typeRoots": ["src/modules/queryPanel/components/perspective"]
  },
  "include": ["src", "../src/telemetry/events.ts"],
  "references": [{ "path": "./tsconfig.node.json" }]
}
